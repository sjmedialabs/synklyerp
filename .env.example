# Supabase (required — no Prisma needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=bizflow@admin.io
SUPER_ADMIN_PASSWORD=Synkly@2026!

# OTP delivery (optional in dev — codes logged when unset)
RESEND_API_KEY=
EMAIL_FROM=SynklyERP <noreply@yourdomain.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OTP_DEV_LOG=true

# Cloudflare Turnstile CAPTCHA (optional in dev — skipped when unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
